<Page x:Class="WPF_Projekt_Emre.pages.GameBoardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="GameBoardPage"
      MinWidth="800"
      MinHeight="600">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.Column="0"
              MinHeight="500"
              MinWidth="550">

            <Grid.Background>
                <ImageBrush ImageSource="/assets/Images/Layout/GameBoard.png"/>
            </Grid.Background>

            <Canvas MinHeight="500"
                    MinWidth="550">

                <ItemsControl ItemsSource="{Binding Fields}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Width="50"
                                   Height="50"
                                   Source="{Binding ImagePath}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding PlayerFigures}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Width="40"
                                   Height="40"
                                   Source="{Binding ImagePath}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </Grid>

        <Border Grid.Row="0"
                Grid.Column="1"
                Grid.RowSpan="2"
                Margin="10"
                Background="LightGray">

            <StackPanel MinWidth="200"
                        VerticalAlignment="Top">

                <TextBlock Text="Spielerübersicht"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="10"/>

                <ItemsControl ItemsSource="{Binding PlayerInfos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="5"
                                    Margin="5"
                                    CornerRadius="6"
                                    BorderThickness="2">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Gray"/>
                                        <Setter Property="Background" Value="#FFF"/>

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="DodgerBlue"/>
                                                <Setter Property="Background" Value="#D0E8FF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel>
                                    <TextBlock Text="{Binding PlayerName}"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding Runde, StringFormat=Runde: {0}}"/>

                                    <TextBlock Text="{Binding Score, StringFormat=Punkte: {0}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
        Grid.Column="0"
        Background="LightBlue"
        Margin="10"
        Height="100"
        VerticalAlignment="Top">

            <StackPanel Orientation="Horizontal"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <TextBlock Text="Am Zug: "
                   FontSize="16"
                   VerticalAlignment="Center"/>

                <TextBlock Text="{Binding CurrentPlayerName}"
                   FontSize="16"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                <TextBlock Text=" | Runde: "
                   FontSize="16"
                   VerticalAlignment="Center"/>

                <TextBlock Text="{Binding CurrentPlayerRound}"
                   FontSize="16"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                <TextBlock Text=" | Punkte: "
                   FontSize="16"
                   VerticalAlignment="Center"/>

                <TextBlock Text="{Binding CurrentPlayerScore}"
                   FontSize="16"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                <Image Width="60"
               Height="60"
               Source="{Binding DiceImageSource}"
               Margin="20,0"
               Cursor="Hand"
               MouseLeftButtonDown="DiceImage_MouseLeftButtonDown"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>