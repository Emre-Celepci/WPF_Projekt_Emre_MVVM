<Page x:Class="WPF_Projekt_Emre.pages.GameOverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="GameOverPage">

    <Grid Background="LightGray"
          Margin="20">

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="{Binding WinnerText}"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="DarkGreen"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>

            <ListView ItemsSource="{Binding PlayerResults}"
                      Width="300"
                      Margin="0,0,0,20">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Platz"
                                        Width="50"
                                        DisplayMemberBinding="{Binding Platz}"/>

                        <GridViewColumn Header="Name"
                                        Width="150"
                                        DisplayMemberBinding="{Binding PlayerName}"/>

                        <GridViewColumn Header="Punkte"
                                        Width="80"
                                        DisplayMemberBinding="{Binding Score}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Button Content="Zurück zum Startmenü"
                    Width="200"
                    Height="40"
                    Command="{Binding BackToMenuCommand}"
                    Background="DarkSlateBlue"
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Page>