<Page x:Class="WPF_Projekt_Emre.pages.PlayerConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="LightGray">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Spieler Konfiguration"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            Width="450">

                    <TextBlock Text="{Binding PlayerLabel}"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Name:" FontWeight="SemiBold"/>

                    <TextBox Text="{Binding PlayerName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,10"
                             Height="30"/>

                    <TextBlock Text="Figur wählen:" FontWeight="SemiBold"/>

                    <ItemsControl ItemsSource="{Binding AvailableFigures}"
                                  Margin="0,5,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel ItemHeight="60"
                                           ItemWidth="60"
                                           HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectFigureCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Width="55"
                                        Height="55"
                                        Margin="5"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Image Source="{Binding ImagePath}"
                                           Width="50"
                                           Height="50">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Opacity" Value="1.0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10">

                        <Button Content="Spieler hinzufügen"
                                Command="{Binding AddPlayerCommand}"
                                Visibility="{Binding AddPlayerButtonVisibility}"
                                Margin="5"
                                Padding="10,5"
                                Background="Aquamarine"
                                Foreground="Black"/>

                        <Button Content="Zurück"
                                Command="{Binding BackCommand}"
                                Margin="5"
                                Padding="10,5"
                                Background="Aquamarine"
                                Foreground="Black"/>
                    </StackPanel>

                    <Separator Margin="0,15"/>

                    <TextBlock Text="Bisherige Spieler:"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>

                    <ItemsControl ItemsSource="{Binding Players}"
                                  Background="#EEE"
                                  Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Margin="5"
                                            VerticalAlignment="Center">

                                    <TextBlock Text="{Binding Number, StringFormat=Spieler {0}:}"
                                               FontWeight="Bold"
                                               Width="90"
                                               VerticalAlignment="Center"/>

                                    <Image Width="40"
                                           Height="40"
                                           Source="{Binding ImagePath}"
                                           Margin="5,0,10,0"/>

                                    <TextBlock Text="{Binding PlayerName}"
                                               FontSize="16"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Spiel starten"
                            Command="{Binding StartGameCommand}"
                            Visibility="{Binding StartButtonVisibility}"
                            Margin="10"
                            HorizontalAlignment="Center"
                            FontSize="16"
                            Padding="10,5"
                            Background="Aquamarine"
                            Foreground="Black"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Page>