<Page x:Class="WPF_Projekt_Emre.pages.HighscorePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HighscorePage">

    <Grid Background="LightCyan">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="🏆 Highscores (Top 10)"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       TextAlignment="Center"/>

            <ListView ItemsSource="{Binding Highscores}"
                      Width="350"
                      Margin="0,0,0,20">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Platz"
                                        Width="50"
                                        DisplayMemberBinding="{Binding Platz}"/>

                        <GridViewColumn Header="Spieler"
                                        Width="180"
                                        DisplayMemberBinding="{Binding PlayerName}"/>

                        <GridViewColumn Header="Punkte"
                                        Width="100"
                                        DisplayMemberBinding="{Binding Score}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Button Content="Zurück zum Start"
                    Width="200"
                    Height="40"
                    Command="{Binding BackCommand}"
                    Background="SkyBlue"
                    Foreground="Black"/>
        </StackPanel>
    </Grid>
</Page>